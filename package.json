{
  "name": "grouter-auth",
  "version": "5.2.1",
  "description": "Universal AI router — OAuth + API Key providers (Claude, GitHub Copilot, Gemini, Kimi, Kiro, Qwen, Cursor, OpenRouter, Groq…) behind one OpenAI-compatible local proxy",
  "author": "gxdev",
  "license": "MIT",
  "keywords": [
    "ai",
    "router",
    "proxy",
    "openai",
    "openai-compatible",
    "oauth",
    "claude",
    "copilot",
    "gemini",
    "qwen",
    "kimi",
    "cli",
    "bun"
  ],
  "bin": {
    "grouter": "dist/grouter"
  },
  "files": [
    "dist/grouter"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "module": "index.ts",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "bun --hot index.ts serve fg",
    "start": "bun index.ts serve fg",
    "prebuild": "bun run scripts/embed-logos.ts",
    "build": "bun build index.ts --target bun --outfile dist/grouter && chmod +x dist/grouter",
    "deploy": "bun run build && bun link && echo '\\n✓ Global binary updated — run: grouter serve'",
    "prepare": "test -f dist/grouter || bun run build",
    "prepublishOnly": "bun run build",
    "install:cli": "bash setup.sh",
    "uninstall:cli": "bash uninstall.sh",
    "docker:install": "bash scripts/docker-install.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f grouter",
    "docker:shell": "docker compose exec grouter sh",
    "docker:add": "docker compose exec grouter grouter add",
    "docker:rebuild": "docker compose build --pull && docker compose up -d"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "open": "^11.0.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
